# ── API Keys ──────────────────────────────────────────────────────────────────
# At least one LLM provider key is required. If both are set, Gemini is used
# unless BT_LLM_PROVIDER is set explicitly.

# Anthropic (Claude)
BT_ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (optional — free tier available)
BT_GEMINI_API_KEY=AIza...

# The Odds API (optional — enables odds analyst)
# BT_ODDS_API_KEY=

# Web UI auth key (optional — if set, all API requests must include it)
# BT_API_KEY=

# ── LLM Provider ──────────────────────────────────────────────────────────────
# "auto" (default): Gemini if BT_GEMINI_API_KEY is set, else Anthropic
# Options: auto | anthropic | gemini | stub
# BT_LLM_PROVIDER=auto

# ── Anthropic Model Selection ─────────────────────────────────────────────────
# BT_ANALYST_MODEL=claude-sonnet-4-5
# BT_MANAGER_MODEL_CONTESTED=claude-opus-4-5
# BT_MANAGER_MODEL_MODERATE=claude-sonnet-4-5
# BT_MANAGER_MODEL_CONSENSUS=claude-haiku-4-5

# ── Gemini Model Selection ────────────────────────────────────────────────────
# BT_GEMINI_ANALYST_MODEL=gemini-2.5-flash
# BT_GEMINI_MANAGER_MODEL_CONTESTED=gemini-2.5-flash
# BT_GEMINI_MANAGER_MODEL_MODERATE=gemini-2.5-flash
# BT_GEMINI_MANAGER_MODEL_CONSENSUS=gemini-2.5-flash
# BT_GEMINI_RPM=25
# BT_GEMINI_THINKING_BUDGET=1024
# BT_GEMINI_REQUEST_DELAY=0

# ── LLM Behavior ──────────────────────────────────────────────────────────────
# BT_LLM_TEMPERATURE=0.7
# BT_LLM_MAX_TOKENS=2048
# BT_LLM_MAX_RETRIES=3
# BT_DISCUSSION_MAX_CHARS=500

# ── Concurrency ───────────────────────────────────────────────────────────────
# BT_MAX_CONCURRENT_MATCHUPS=1
# BT_MAX_CONCURRENT_API_CALLS=4

# ── Database ──────────────────────────────────────────────────────────────────
# BT_DATABASE_URL=bracket_team.db

# ── Logging ───────────────────────────────────────────────────────────────────
# Full LLM conversation log (leave unset to disable)
# BT_LLM_CONVERSATION_LOG=/tmp/conversations.log
